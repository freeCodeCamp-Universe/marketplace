{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "validate:raw": {
      "inputs": [
        "AGENTS.md",
        "README.md",
        "agents/**/*.md",
        "plugins/*/plugin.json",
        "plugins/*/README.md",
        "plugins/**/agents/**/*.md",
        "plugins/**/skills/**/agents/**/*.md",
        "plugins/**/skills/**/SKILL.md",
        "plugins/**/adapters/**/*",
        "claude-native/**/*",
        "skills/**/SKILL.md",
        "scripts/**/*.ts",
        "templates/**/*"
      ],
      "cache": false
    },
    "catalog:check:raw": {
      "inputs": [
        "README.md",
        "agents/**/*.md",
        "plugins/*/plugin.json",
        "plugins/**/skills/**/SKILL.md",
        "plugins/**/skills/**/agents/**/*.md",
        "plugins/**/agents/**/*.md",
        "claude-native/**/.claude-plugin/plugin.json",
        "skills/**/SKILL.md",
        "scripts/**/*.ts"
      ],
      "outputs": [],
      "cache": false
    },
    "test:raw": {
      "inputs": ["scripts/**/*.ts", "tests/**/*.ts", "vitest.config.ts"],
      "outputs": []
    },
    "lint:raw": {
      "inputs": ["**/*.ts", "**/*.js", ".oxlintrc.json"],
      "outputs": []
    },
    "format:check:raw": {
      "inputs": ["**/*.ts", "**/*.js", "**/*.json", "**/*.md"],
      "outputs": []
    },
    "format": {
      "cache": false
    },
    "check": {
      "dependsOn": ["validate:raw", "catalog:check:raw", "test:raw", "lint:raw", "format:check:raw"]
    }
  }
}
